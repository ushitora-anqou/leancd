{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "pullSecrets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": { "name": { "type": "string" } },
            "required": ["name"]
          }
        }
      }
    },
    "namespace": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "namespaced": { "type": "boolean" },
        "clusterRoleName": { "type": "string" },
        "namespacedClusterRoleName": { "type": "string" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "kubeApiCidr": { "type": "string" },
        "kubeApiPort": { "type": "integer" },
        "egressCidr": { "type": "string" },
        "gitPorts": { "type": "array", "items": { "type": "integer" } },
        "otlpPort": { "type": "integer" },
        "dns": {
          "type": "object",
          "properties": {
            "namespace": { "type": "string" },
            "podSelector": { "type": "object" },
            "port": { "type": "integer" }
          }
        }
      }
    },
    "git": {
      "type": "object",
      "properties": {
        "credentialsSecretName": { "type": "string" },
        "credentialsOptional": { "type": "boolean" }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "repoUrl": { "type": "string" },
        "branch": { "type": "string" },
        "path": { "type": "string" },
        "namespace": { "type": "string" },
        "pollInterval": { "type": "string" },
        "workDir": { "type": "string" },
        "lockLeaseDurationSecs": { "type": "string" },
        "lockWaitTimeoutSecs": { "type": "string" },
        "cacheMaxObjectBytes": { "type": "string" }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "otlpEndpoint": { "type": "string" },
        "otlpProtocol": { "type": "string" }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "limits": { "type": "object" },
        "requests": { "type": "object" }
      }
    },
    "dashboards": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "configMapName": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "extraEnv": { "type": "array" },
    "replicaCount": { "type": "integer" },
    "strategy": { "type": "string" },
    "terminationGracePeriodSeconds": { "type": "integer" },
    "args": { "type": "array", "items": { "type": "string" } },
    "podSecurityContext": { "type": "object" },
    "containerSecurityContext": { "type": "object" },
    "livenessProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "startupProbe": { "type": "object" },
    "tmpVolume": {
      "type": "object",
      "properties": { "enabled": { "type": "boolean" } }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"] }
      }
    },
    "priorityClass": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "name": { "type": "string" },
        "value": { "type": "integer" }
      }
    }
  }
}
