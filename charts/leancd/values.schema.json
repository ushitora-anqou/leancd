{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "namespace": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "namespaced": { "type": "boolean" },
        "clusterRoleName": { "type": "string" },
        "namespacedClusterRoleName": { "type": "string" }
      }
    },
    "dashboards": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "configMapName": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "config": { "type": "object" },
    "metrics": { "type": "object" },
    "resources": { "type": "object" },
    "extraEnv": { "type": "array" }
  }
}
